# RegScan API credentials — copy to .env.local and fill in. NEVER commit .env.local.
# All keys are read server-side only and are never sent to the browser.

# --- DVSA MOT History API (OAuth2 client credentials + API key) ---
# Register: https://documentation.history.mot.api.gov.uk/
DVSA_MOT_CLIENT_ID=
DVSA_MOT_CLIENT_SECRET=
DVSA_MOT_API_KEY=
# Token endpoint DVSA emails you, e.g. https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
DVSA_MOT_TOKEN_URL=
# Usually fine to leave as the default:
DVSA_MOT_SCOPE=https://tapi.dvsa.gov.uk/.default
DVSA_MOT_BASE_URL=https://history.mot.api.gov.uk/v1/trade/vehicles/registration

# --- DVLA Vehicle Enquiry Service (tax, make, colour, CO2) ---
# Register: https://developer-portal.driver-vehicle-licensing.api.gov.uk/
DVLA_VES_API_KEY=
DVLA_VES_BASE_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# --- TfL Unified API (London air quality). Use the "500 Requests per min" product
#     Primary key, NOT the TrackernetFeedPublic key. ---
TFL_APP_KEY=
TFL_BASE_URL=https://api.tfl.gov.uk

# --- Add more providers here as you wire them in lib/providers/ ---
